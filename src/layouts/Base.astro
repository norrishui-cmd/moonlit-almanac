---
import { SITE } from '../consts';
import '../styles/global.css';
interface Crumb { label: string; href?: string; }
interface Props {
  title: string;
  description: string;
  path?: string;
  jsonLd?: object | object[];
  crumbs?: Crumb[];
}
const { title, description, path = '/', jsonLd, crumbs = [] } = Astro.props;
const canonical = new URL(path, SITE.url).href;
const nav = [
  { href: '/release-date', label: 'Release' },
  { href: '/beginner-guide', label: 'Guide' },
  { href: '/characters', label: 'Characters' },
  { href: '/nokturna', label: 'Nokturna' },
  { href: '/romance', label: 'Romance' },
];
const here = Astro.url.pathname.replace(/\/$/, '') || '/';
const ld = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.brand} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500;700&display=swap"
    />
    {ld.map((obj) => <script type="application/ld+json" set:html={JSON.stringify(obj)} />)}
  </head>
  <body>
    <header class="site-header">
      <div class="wrap bar">
        <a class="brand" href="/" aria-label={`${SITE.brand} home`}>
          <span class="moon" aria-hidden="true"></span>
          <span class="mark">Moonlight Peaks <em>Wiki &amp; Guide</em></span>
        </a>
        <nav class="nav" aria-label="Primary">
          {nav.map((n) => (
            <a href={n.href} aria-current={here === n.href ? 'page' : undefined}>{n.label}</a>
          ))}
        </nav>
      </div>
    </header>
    {crumbs.length > 0 && (
      <div class="wrap">
        <nav class="crumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          {crumbs.map((c) => (
            <span>{' / '}{c.href ? <a href={c.href}>{c.label}</a> : c.label}</span>
          ))}
        </nav>
      </div>
    )}
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="wrap">
        <div class="row">
          <span>{SITE.brand}</span>
          <span class="links">
            <a href="/about">About</a>
            <a href="/privacy">Privacy</a>
            <span>Updated {SITE.updated}</span>
          </span>
        </div>
        <p class="disclaimer">
          Moonlight Peaks Wiki &amp; Guide is an independent, fan-made guide. It is not affiliated
          with, endorsed by, or connected to Little Chicken Game Company or XSEED Games. “Moonlight
          Peaks” and all related names and assets are trademarks of their respective owners.
        </p>
      </div>
    </footer>
  </body>
</html>
