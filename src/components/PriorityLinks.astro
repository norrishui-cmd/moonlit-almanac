---
import type { PriorityLink } from '../data/priorityLinks';

interface Props {
  title: string;
  note: string;
  links: PriorityLink[];
}

const { title, note, links } = Astro.props;
---
<section class="priority-links" aria-labelledby={title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}>
  <div class="priority-head">
    <h2 id={title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}>{title}</h2>
    <span>{note}</span>
  </div>
  <div class="priority-grid">
    {links.map((item) => (
      <a class="priority-card" href={item.href}>
        <strong>{item.label}</strong>
        <span>{item.note}</span>
      </a>
    ))}
  </div>
</section>

<style>
  .priority-links { margin: 34px 0 0; }
  .priority-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin: 0 0 14px;
  }
  .priority-head h2 {
    font-family: var(--display);
    font-size: clamp(1.35rem, 3vw, 1.8rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .priority-head span {
    color: var(--faint);
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .priority-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }
  @media (min-width: 620px) {
    .priority-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (min-width: 920px) {
    .priority-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  .priority-card {
    border: 1px solid var(--line);
    border-radius: 10px;
    background: color-mix(in srgb, var(--surface) 88%, var(--candle) 12%);
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-height: 104px;
    padding: 13px 14px;
    text-decoration: none;
    transition: border-color .15s ease, transform .15s ease;
  }
  .priority-card:hover {
    border-color: color-mix(in srgb, var(--candle) 55%, var(--line));
    transform: translateY(-2px);
  }
  .priority-card strong {
    color: var(--mist);
    font-family: var(--display);
    font-size: 1.03rem;
    font-weight: 600;
    line-height: 1.2;
  }
  .priority-card span {
    color: var(--muted);
    font-size: 0.84rem;
    line-height: 1.45;
  }
</style>
