---
import Base from '../layouts/Base.astro';
import { GAME, SITE } from '../consts';
import { t, withLocale, type LocaleCode } from '../data/i18n.ts';
import type { SeoPage } from '../data/seoGraph.ts';

interface Props {
  page: SeoPage;
  sourcePath?: string;
  locale?: LocaleCode;
}

const { page, sourcePath = page.path, locale = 'en' } = Astro.props;
const tx = t(locale);
const canonical = new URL(page.path, SITE.url).href;
const crumbs = [
  { label: page.hub.replace(' Hub', ''), href: page.hubPath },
  { label: page.h1.replace(/^Moonlight Peaks /, '') },
];

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: tx.home, item: new URL(withLocale('/', locale), SITE.url).href },
    { '@type': 'ListItem', position: 2, name: page.hub.replace(' Hub', ''), item: new URL(page.hubPath, SITE.url).href },
    { '@type': 'ListItem', position: 3, name: page.h1, item: canonical },
  ],
};

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: page.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a },
  })),
};

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: page.h1,
  description: page.description,
  url: canonical,
  dateModified: '2026-06-30',
  publisher: { '@type': 'Organization', name: SITE.brand },
  about: { '@type': 'VideoGame', name: GAME.title, datePublished: GAME.releaseISO, gamePlatform: GAME.platforms },
};

const howToLd = page.kind === 'guide'
  ? {
      '@context': 'https://schema.org',
      '@type': 'HowTo',
      name: page.h1,
      description: page.description,
      step: page.sections.map((section, index) => ({
        '@type': 'HowToStep',
        position: index + 1,
        name: section.title,
        text: section.body,
      })),
    }
  : null;

const itemListLd = page.kind === 'hub' || page.kind === 'list'
  ? {
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      itemListElement: page.related.map((item, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: item.label,
        url: new URL(item.href, SITE.url).href,
      })),
    }
  : null;

const jsonLd = [breadcrumbLd, faqLd, articleLd, howToLd, itemListLd].filter(Boolean);
---
<Base title={page.title} description={page.description} path={page.path} sourcePath={sourcePath} locale={locale} jsonLd={jsonLd} crumbs={crumbs}>
  <article class="page seo-page">
    <div class="wrap">
      <p class="eyebrow">{page.hub} / {page.kind}</p>
      <h1>{page.h1}</h1>
      <p class="intro">{page.intro}</p>

      {page.sections.map((section) => (
        <section class="seo-section">
          <h2>{section.title}</h2>
          <p>{section.body}</p>
        </section>
      ))}

      <section class="seo-section">
        <h2>{tx.relatedGuides}</h2>
        <div class="seo-links">
          {page.related.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </div>
      </section>

      <section class="seo-section">
        <h2>{tx.faq}</h2>
        {page.faqs.map((faq) => (
          <div class="seo-faq">
            <h3>{faq.q}</h3>
            <p>{faq.a}</p>
          </div>
        ))}
      </section>

      <section class="seo-section">
        <h2>{tx.latestNews}</h2>
        <p>
          {tx.latestNewsText}
        </p>
      </section>
    </div>
  </article>

  <style>
    .seo-page h2 { margin-top: 24px; }
    .seo-section { margin: 0 0 18px; }
    .seo-links {
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
      margin-top: 10px;
    }
    @media (min-width: 640px) {
      .seo-links { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    .seo-links a {
      border: 1px solid var(--line);
      border-radius: 8px;
      color: var(--mist);
      padding: 10px 12px;
      text-decoration: none;
    }
    .seo-links a:hover { border-color: color-mix(in srgb, var(--candle) 55%, var(--line)); }
    .seo-faq {
      border-left: 2px solid var(--candle-dim);
      margin: 12px 0;
      padding-left: 14px;
    }
    .seo-faq h3 {
      color: var(--mist);
      font-family: var(--display);
      font-size: 1.04rem;
      font-weight: 600;
      margin: 0 0 4px;
    }
    .seo-faq p { margin: 0; }
  </style>
</Base>
