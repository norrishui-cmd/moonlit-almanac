---
// One responsive 16:9 YouTube player. Click the cover to play in place.
// <YouTube id="VIDEO_ID" title="..." />   (id = the part after watch?v= or youtu.be/)
interface Props { id: string; title?: string; }
const { id, title = 'YouTube video' } = Astro.props;
---
<div class="yt-lite" data-id={id} role="button" tabindex="0" aria-label={`Play: ${title}`}>
  <img
    class="yt-thumb"
    src={`https://i.ytimg.com/vi/${id}/maxresdefault.jpg`}
    alt={title}
    loading="lazy"
    width="1280" height="720"
    onerror={`this.onerror=null;this.src='https://i.ytimg.com/vi/${id}/hqdefault.jpg'`}
  />
  <span class="yt-play" aria-hidden="true"></span>
  <span class="yt-cap">{title}</span>
</div>

<style>
  .yt-lite { position: relative; display: block; width: 100%; max-width: 640px; margin: 0 auto; aspect-ratio: 16 / 9; border: 1px solid var(--line); border-radius: 12px; overflow: hidden; background: #000; cursor: pointer; }
  .yt-thumb { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.85; transition: opacity .15s ease; }
  .yt-lite:hover .yt-thumb { opacity: 1; }
  .yt-play { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 64px; height: 46px; border-radius: 12px; background: rgba(192,67,106,0.92); }
  .yt-play::before { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-40%, -50%); border-style: solid; border-width: 10px 0 10px 18px; border-color: transparent transparent transparent #fff; }
  .yt-cap { position: absolute; left: 0; right: 0; bottom: 0; padding: 9px 11px; font-size: 0.8rem; color: #fff; background: linear-gradient(transparent, rgba(0,0,0,0.72)); font-family: var(--body); pointer-events: none; }
  .yt-lite:focus-visible { outline: 2px solid var(--candle); outline-offset: 2px; }
</style>

<script>
  document.querySelectorAll('.yt-lite').forEach((box) => {
    const play = () => {
      const id = box.getAttribute('data-id');
      if (!id || box.querySelector('iframe')) return;
      const f = document.createElement('iframe');
      f.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1`;
      f.title = box.getAttribute('aria-label') || 'YouTube video';
      f.allow = 'autoplay; encrypted-media; picture-in-picture; fullscreen';
      f.sandbox = 'allow-scripts allow-same-origin allow-presentation';
      f.setAttribute('allowfullscreen', '');
      // Inline styles so the iframe fills the box even though it's created at runtime:
      f.style.position = 'absolute';
      f.style.top = '0';
      f.style.left = '0';
      f.style.width = '100%';
      f.style.height = '100%';
      f.style.border = '0';
      box.innerHTML = '';
      box.appendChild(f);
    };
    box.addEventListener('click', play);
    box.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); play(); } });
  });
</script>
