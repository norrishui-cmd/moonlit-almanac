---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';

const faq = [
  { q: 'Is Moonlight Peaks multiplayer?', a: 'No. Moonlight Peaks is a single-player cozy life sim — the official store page lists it as singleplayer, and there is no announced co-op or online mode.' },
  { q: 'Is Moonlight Peaks on Steam Deck?', a: 'Yes. The developers have confirmed Steam Deck as a supported platform alongside PC. It also recommends playing with a gamepad, though keyboard and mouse are supported.' },
  { q: 'How much does Moonlight Peaks cost?', a: 'It is $34.99 on Steam (PC/Mac), Nintendo Switch, and Android, and $39.99 on Nintendo Switch 2. There is a 15% discount across all platforms for the first 7 days after launch (and a 15% pre-order discount).' },
  { q: 'Can I upgrade from Switch to Switch 2?', a: 'Yes. If you buy the Nintendo Switch version, you can upgrade to the Switch 2 version with a $5 upgrade pack.' },
  { q: 'Is Moonlight Peaks on mobile?', a: 'Yes — it launches on Android via Google Play, alongside PC, Steam Deck, and the Switch family.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Platforms', item: new URL('/platforms', SITE.url).href },
  ] },
];
---
<Base
  title={`Moonlight Peaks Platforms & Price — Switch 2, Steam Deck, Mac & Mobile | ${SITE.brand}`}
  description="Every platform Moonlight Peaks launches on (Steam, Mac, Steam Deck, Switch, Switch 2, Android), full pricing including the Switch 2 edition, multiplayer, and controller support."
  path="/platforms"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Platforms' }]}
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entry · Platforms</p>
      <h1>Moonlight Peaks <em>platforms</em> & price</h1>
      <p class="intro">
        Where you can play {GAME.title}, what each version costs, whether it's multiplayer, and
        controller support — all confirmed details, updated {SITE.updated}.
      </p>

      <h2>Every platform</h2>
      <table class="facts">
        <tr><th>Steam (PC & Mac)</th><td>Yes — Windows and Mac.</td></tr>
        <tr><th>Steam Deck</th><td>Yes — confirmed by the developers.</td></tr>
        <tr><th>Nintendo Switch</th><td>Yes — at launch.</td></tr>
        <tr><th>Nintendo Switch 2</th><td>Yes — a separate edition; the Switch demo also runs on Switch 2.</td></tr>
        <tr><th>Android</th><td>Yes — via Google Play.</td></tr>
        <tr><th>PlayStation / Xbox</th><td>Not announced at this time.</td></tr>
      </table>

      <h2>Price</h2>
      <ul>
        <li><strong>$34.99</strong> — Steam (PC/Mac), Nintendo Switch, and Android.</li>
        <li><strong>$39.99</strong> — Nintendo Switch 2 edition.</li>
        <li><strong>$5 upgrade</strong> — buy on Switch, upgrade to the Switch 2 version for $5.</li>
        <li><strong>15% off</strong> across all platforms for the first 7 days after launch (plus a 15% pre-order discount).</li>
      </ul>

      <h2>Is it multiplayer?</h2>
      <p>
        <strong>No — it's single-player.</strong> The official Steam page lists Moonlight Peaks as a
        singleplayer experience, with no announced co-op. It's built around your own vampire, your
        farm, and your relationships with the town's roughly two dozen romanceable residents.
      </p>

      <h2>Controller support</h2>
      <p>
        The game recommends playing with a <strong>gamepad</strong> for the best experience, though
        keyboard and mouse are fully supported.
      </p>

      <h2>Cross-save & cross-platform</h2>
      <p>No cross-save or cross-platform play has been announced. We'll note any change here if the developers confirm it.</p>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout">
        Related: try the <a href="/demo">free demo</a>, check the <a href="/release-date">release date</a>,
        or see how it <a href="/moonlight-peaks-vs-stardew-valley">compares to Stardew Valley</a>.
      </div>
    </div>
  </article>
</Base>
