---
import TopicPage from '../../components/TopicPage.astro';
import { activitiesSection, activities } from '../../data/activities';

export function getStaticPaths() {
  return activities.map((it, i) => ({
    params: { slug: it.slug },
    props: { item: it, prev: activities[(i - 1 + activities.length) % activities.length], next: activities[(i + 1) % activities.length] },
  }));
}
const { item, prev, next } = Astro.props;
---
<TopicPage section={activitiesSection} item={item} prev={prev} next={next} />
