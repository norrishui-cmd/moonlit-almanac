---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';

const faq = [
  { q: 'Can you customize your character in Moonlight Peaks?', a: 'Yes. There is a full character creator — already playable in the free demo — where you set your vampire\u2019s skin tone, eyes, hairstyle, makeup and outfits. The options are designed to be inclusive of any style, with a supernatural twist.' },
  { q: 'Is the Moonlight Peaks character creator gender-neutral?', a: 'Yes. The character models are intentionally gender-neutral, and dating is not gender-locked, so you can build the vampire you want and romance anyone regardless of how you present.' },
  { q: 'Can you change your appearance after creating your character?', a: 'Yes. The Alter Ego Elixir is a potion that changes your appearance, so you are not permanently locked into your starting look. Exact details land at launch.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Character creator', item: new URL('/character-creator', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Character Creator — Customization Options"
  description="How character creation works in Moonlight Peaks: the demo's vampire creator — skin tones, eyes, hairstyles, makeup, and outfits, gender-neutral and inclusive."
  path="/character-creator"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Character creator' }]}
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Entry · Character creator</p>
      <h1>Moonlight Peaks <em>character creator</em></h1>
      <p class="intro">
        Before you tend a single moonlit crop, you design your vampire. Here's what {GAME.title}'s
        character creator lets you do — based on the official details and the free demo, which already
        includes it. Updated {SITE.updated}.
      </p>

      <h2>Try it now in the free demo</h2>
      <p>
        The character creator is one of the headline features of the free demo on Steam and the
        Nintendo eShop, so you can build your vampire and experiment with looks right now, ahead of the
        full launch. See our <a href="/demo">demo guide</a> for what else is included.
      </p>

      <h2>What you can customize</h2>
      <p>
        You shape your vampire's appearance across skin tones, eyes, hairstyles, makeup and outfits.
        The studio describes the options as inclusive of any style, all with a supernatural flair —
        whether you want to look casual, whimsical, or, fittingly, drop-dead gorgeous.
      </p>

      <h2>Gender-neutral by design</h2>
      <p>
        Character models are intentionally gender-neutral, and the dating system isn't gender-locked.
        In other words, you build the vampire you want and can <a href="/romance">romance</a> any
        eligible resident regardless of how you present.
      </p>

      <h2>Not locked in — the Alter Ego Elixir</h2>
      <p>
        If you change your mind later, you won't be stuck with your starting look: the
        <strong>Alter Ego Elixir</strong>, one of the potions you can brew, changes your appearance.
        See <a href="/magic">magic & potions</a> for how brewing works.
      </p>

      <h2>Coming at launch ({GAME.releaseLabel})</h2>
      <ul>
        <li>The full list of <strong>options</strong> — hairstyles, faces, skin tones and outfit pieces.</li>
        <li>Whether there are <strong>presets</strong> and how much you can fine-tune.</li>
        <li>Any cosmetics or styles you <strong>unlock</strong> over the course of the full game.</li>
      </ul>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Pre-launch entry — full option lists land at launch. Related:
        <a href="/shapeshifting">shapeshifting</a>, <a href="/characters">characters</a>,
        <a href="/demo">the demo</a>.
      </div>
    </div>
  </article>
</Base>
