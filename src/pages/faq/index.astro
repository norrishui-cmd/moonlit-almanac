---
import Base from '../../layouts/Base.astro';
import { SITE, GAME } from '../../consts';
import PriorityLinks from '../../components/PriorityLinks.astro';
import { faqs, faqCatLabels } from '../../data/faq';
import { faqPriorityLinks } from '../../data/priorityLinks';

const cats = ['platforms', 'romance', 'characters', 'world', 'general'] as const;
const plain = (f) => [f.a, ...(f.more || [])].join(' ');

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'FAQ', item: new URL('/faq', SITE.url).href },
  ] },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({
    '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: plain(f) },
  })) },
];
---
<Base
  title="Moonlight Peaks FAQ — Release, Romance, Demo & More"
  description="Answers to the most-asked Moonlight Peaks questions: release date, price, platforms, multiplayer, combat, marriage, romance options, the demo, and gameplay."
  path="/faq"
  jsonLd={jsonLd}
  crumbs={[{ label: 'FAQ' }]}
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Hub · FAQ</p>
      <h1>Moonlight Peaks <em>FAQ</em></h1>
      <p class="intro">
        Quick, sourced answers to the questions players ask most about {GAME.title} ahead of the
        {GAME.releaseLabel} launch. Each question has its own page. We answer only what is confirmed
        or reported, and mark anything still unknown rather than guessing. Updated {SITE.updated}.
      </p>

      <PriorityLinks
        title="Most-searched FAQ answers"
        note="quick answers"
        links={faqPriorityLinks}
      />

      <h2>How to use this FAQ</h2>
      <p>
        Use this page when you need a direct answer, then open the linked guide when you need detail.
        Platform and demo questions usually lead to release-date pages, while romance and character
        questions lead to gift, schedule, heart-event, and family pages.
      </p>

      {cats.map((cat) => {
        const items = faqs.filter((f) => f.cat === cat);
        if (items.length === 0) return null;
        return (
          <section class="grp">
            <div class="grp-head"><h2>{faqCatLabels[cat]}</h2><span class="note">{items.length} questions</span></div>
            <ul class="q-list">
              {items.map((f) => (
                <li><a href={`/faq/${f.slug}`}>{f.q}</a></li>
              ))}
            </ul>
          </section>
        );
      })}

      <div class="callout">
        More: <a href="/release-date">release & platforms</a> · <a href="/characters">characters</a> ·
        <a href="/romance">romance</a> · <a href="/previews">previews & guides</a>.
      </div>
    </div>
  </article>

  <style>
    .grp { margin: 0 0 22px; }
    .grp-head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin: 0 0 10px; border-bottom: 1px solid var(--line); padding-bottom: 6px; }
    .grp-head h2 { margin: 0; }
    .grp-head .note { font-family: var(--mono); font-size: 0.7rem; color: var(--faint); text-transform: uppercase; letter-spacing: 0.08em; }
    .q-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 8px; }
    .q-list a { display: block; border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 12px 14px; color: var(--mist); font-weight: 500; transition: border-color .15s ease, transform .15s ease; }
    .q-list a:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); transform: translateY(-1px); }
  </style>
</Base>
