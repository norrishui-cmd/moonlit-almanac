---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../consts';
import { previews } from '../../data/previews';

export function getStaticPaths() {
  return previews.map((article) => ({ params: { slug: article.slug }, props: { article } }));
}
const { article } = Astro.props;
const url = new URL(`/previews/${article.slug}`, SITE.url).href;
const imgUrl = new URL(article.image, SITE.url).href;
const related = [
  ...previews.filter((p) => p.slug !== article.slug && p.category === article.category),
  ...previews.filter((p) => p.slug !== article.slug && p.category !== article.category),
].slice(0, 3);

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Demo previews', item: new URL('/previews', SITE.url).href },
    { '@type': 'ListItem', position: 3, name: article.title, item: url },
  ] },
  { '@context': 'https://schema.org', '@type': 'Article', headline: article.title, description: article.dek, image: imgUrl, mainEntityOfPage: url, author: { '@type': 'Organization', name: SITE.brand }, publisher: { '@type': 'Organization', name: SITE.brand }, datePublished: '2026-06-01', dateModified: '2026-06-30' },
];
---
<Base
  title={article.title.includes('Moonlight Peaks') ? article.title : `${article.title} · Moonlight Peaks`}
  description={article.dek}
  path={`/previews/${article.slug}`}
  jsonLd={jsonLd}
  ogImage={article.image}
  crumbs={[{ label: 'Demo previews', href: '/previews' }, { label: article.title }]}
  showExport
>
  <article class="page">
    <div class="wrap">
      <img class="article-hero" src={article.image} alt={`${article.title} — Moonlight Peaks`} width="1200" height="630" fetchpriority="high" />
      <p class="eyebrow">{article.category === 'guide' ? 'Guide' : article.category === 'daily' ? 'Daily' : 'Preview'} · {article.tag}</p>
      <h1>{article.title}</h1>
      <p class="intro">{article.dek}</p>
      <p class="pl-meta-line">{article.readTime} · Updated {article.date}</p>

      {article.body.map((b) => (
        b.type === 'h2' ? <h2>{b.text}</h2>
        : b.type === 'ul' ? <ul>{(b.items || []).map((i) => (<li>{i}</li>))}</ul>
        : b.type === 'callout' ? <div class="callout">{b.text}</div>
        : b.type === 'image' ? (
            <figure class="article-fig">
              <img src={b.src} alt={b.caption || article.title} loading="lazy" />
              {b.caption && <figcaption>{b.caption}</figcaption>}
            </figure>
          )
        : <p>{b.text}</p>
      ))}

      <h2>Sources</h2>
      <ul>
        {article.sources.map((s) => (<li><a href={s.url} target="_blank" rel="noopener nofollow">{s.label}</a></li>))}
      </ul>

      <h2>Related articles</h2>
      <div class="rel-grid">
        {related.map((p) => (
          <a class="rel-card" href={`/previews/${p.slug}`}>
            <span class="rel-tag">{p.tag}</span>
            <span class="rel-title">{p.title}</span>
            <span class="rel-dek">{p.dek}</span>
          </a>
        ))}
      </div>

      <div class="callout">
        More: <a href="/previews">all articles</a> · <a href="/release-date">release & demo</a> · <a href="/beginner-guide">beginner guide</a>.
      </div>
    </div>
  </article>

  <style>
    .article-hero { display: block; width: 100%; height: auto; border-radius: var(--radius); border: 1px solid var(--line); margin: 0 0 18px; }
    .pl-meta-line { font-family: var(--mono); font-size: 0.72rem; color: var(--faint); margin: 8px 0 0; }
    .article-fig { margin: 18px 0; }
    .article-fig img { display: block; width: 100%; height: auto; border-radius: var(--radius); border: 1px solid var(--line); }
    .article-fig figcaption { font-family: var(--mono); font-size: 0.68rem; color: var(--faint); margin-top: 6px; text-align: center; }
    .rel-grid { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 6px 0 18px; }
    @media (min-width: 600px) { .rel-grid { grid-template-columns: 1fr 1fr 1fr; } }
    .rel-card { display: flex; flex-direction: column; border: 1px solid var(--line); border-radius: 14px; background: var(--surface); padding: 14px; transition: border-color .15s ease, transform .15s ease; }
    .rel-card:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); transform: translateY(-2px); }
    .rel-tag { font-family: var(--mono); font-size: 0.64rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--candle); }
    .rel-title { font-family: var(--display); font-weight: 600; font-size: 1rem; color: var(--mist); margin: 4px 0 4px; line-height: 1.25; }
    .rel-dek { color: #ded3e6; font-size: 0.82rem; }
  </style>
</Base>
