---
import Base from '../layouts/Base.astro';
import { SITE } from '../consts';

const tools = [
  {
    href: '/tools/platform-picker',
    tag: 'Decision helper',
    title: 'Platform Picker',
    text: 'Answer a few practical questions and get a launch-safe platform recommendation for Steam, Steam Deck, Switch, Switch 2, or Android.',
    status: 'Live',
  },
  {
    href: '/tools/romance-gift-finder',
    tag: 'Relationship planner',
    title: 'Romance Gift Finder',
    text: 'Choose a resident and see romance status, family clues, verified-gift status, and what to check first when the full game launches.',
    status: 'Live',
  },
  {
    href: '/demo',
    tag: 'Demo prep',
    title: 'Demo Guide',
    text: 'Use the demo hub for download notes, what carries over, and the most useful things to test before launch.',
    status: 'Guide',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Tools', item: new URL('/tools', SITE.url).href },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Moonlight Peaks Tools',
    description: 'Interactive Moonlight Peaks tools for platform decisions, romance planning, gifts, and demo preparation.',
    url: new URL('/tools', SITE.url).href,
  },
];
---
<Base
  title="Moonlight Peaks Tools - Platform Picker, Romance Gifts & Player Helpers | Moonlight Peaks Wiki & Guide"
  description="Interactive Moonlight Peaks tools, including a platform picker and romance gift finder built for launch planning without unverified spoilers."
  path="/tools"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Tools' }]}
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Tools / Player helpers</p>
      <h1>Moonlight Peaks <em>tools</em></h1>
      <p class="intro">
        Practical helpers for players who want an answer, not another generic page. These tools are built to stay useful before and after launch:
        confirmed facts stay separate from data that still needs live-game verification.
      </p>

      <section class="tool-grid" aria-label="Moonlight Peaks tools">
        {tools.map((tool) => (
          <a class="tool-card" href={tool.href}>
            <span class="tool-status">{tool.status}</span>
            <span class="tool-tag">{tool.tag}</span>
            <strong>{tool.title}</strong>
            <span>{tool.text}</span>
            <em>Open tool</em>
          </a>
        ))}
      </section>

      <h2>Why these tools are different</h2>
      <div class="tool-notes">
        <div>
          <h3>Built around decisions</h3>
          <p>Each tool answers a player question: where to buy, who to romance, what gift data is trustworthy, and what still needs checking.</p>
        </div>
        <div>
          <h3>No fake certainty</h3>
          <p>Pre-launch pages avoid inventing loved gifts or final performance claims. Unknown details are clearly marked so the pages can be updated cleanly.</p>
        </div>
        <div>
          <h3>Ready for launch updates</h3>
          <p>After July 7, 2026, the same URLs can be expanded with verified gift tables, platform performance, and checklist data.</p>
        </div>
      </div>

      <div class="callout">
        Related hubs: <a href="/platforms">platforms</a>, <a href="/romance">romance</a>, <a href="/characters">characters</a>, and <a href="/demo">demo guide</a>.
      </div>
    </div>
  </article>

  <style>
    .tool-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin: 28px 0 34px; }
    @media (max-width: 820px) { .tool-grid { grid-template-columns: 1fr; } }
    .tool-card {
      position: relative;
      min-height: 220px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding: 18px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: linear-gradient(180deg, var(--surface), var(--ink-2));
      transition: transform .15s ease, border-color .15s ease;
    }
    .tool-card:hover { transform: translateY(-3px); border-color: color-mix(in srgb, var(--candle) 55%, var(--line)); }
    .tool-status { position: absolute; top: 14px; right: 14px; font-family: var(--mono); font-size: 0.62rem; color: var(--candle); border: 1px solid var(--candle-dim); border-radius: 999px; padding: 3px 8px; text-transform: uppercase; }
    .tool-tag { font-family: var(--mono); font-size: 0.68rem; color: var(--faint); text-transform: uppercase; letter-spacing: 0.12em; padding-right: 58px; }
    .tool-card strong { display: block; font-family: var(--display); font-size: 1.35rem; line-height: 1.1; color: var(--mist); }
    .tool-card span:not(.tool-status):not(.tool-tag) { color: var(--muted); font-size: 0.92rem; }
    .tool-card em { margin-top: auto; font-style: normal; color: var(--candle); font-family: var(--mono); font-size: 0.76rem; }
    .tool-notes { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
    @media (max-width: 820px) { .tool-notes { grid-template-columns: 1fr; } }
    .tool-notes > div { border: 1px solid var(--line); border-radius: 12px; padding: 16px; background: var(--surface); }
    .tool-notes h3 { margin-top: 0; }
    .tool-notes p { margin-bottom: 0; color: var(--muted); }
  </style>
</Base>
