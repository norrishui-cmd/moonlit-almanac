---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../consts';
import { news } from '../../data/news';

export function getStaticPaths() {
  return news.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const url = new URL(`/news/${item.slug}`, SITE.url).href;
const published = `${item.date}T00:00:00Z`;
const related = news.filter((entry) => entry.slug !== item.slug).slice(0, 3);
const fmt = (iso: string) => {
  const d = new Date(`${iso}T00:00:00`);
  return isNaN(d.getTime()) ? iso : d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'News', item: new URL('/#latest-news', SITE.url).href },
      { '@type': 'ListItem', position: 3, name: item.title, item: url },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'NewsArticle',
    headline: item.title,
    description: item.body,
    mainEntityOfPage: url,
    datePublished: published,
    dateModified: published,
    author: { '@type': 'Organization', name: SITE.brand },
    publisher: { '@type': 'Organization', name: SITE.brand },
  },
];
---
<Base
  title={`${item.title} | Moonlight Peaks News`}
  description={item.body}
  path={`/news/${item.slug}`}
  jsonLd={jsonLd}
  crumbs={[{ label: 'News', href: '/#latest-news' }, { label: item.title }]}
>
  <article class="page news-page">
    <div class="wrap">
      <p class="eyebrow">News / {fmt(item.date)}</p>
      <h1>{item.title}</h1>
      <p class="intro">{item.body}</p>

      <div class="news-body-long">
        {item.details.map((paragraph) => <p>{paragraph}</p>)}
      </div>

      {item.sourceUrl && item.sourceLabel && (
        <>
          <h2>Source</h2>
          <p><a href={item.sourceUrl} target="_blank" rel="noopener nofollow noreferrer">{item.sourceLabel}</a></p>
        </>
      )}

      <h2>Related News</h2>
      <div class="news-related">
        {related.map((entry) => (
          <a class="news-related-card" href={`/news/${entry.slug}`}>
            <span>{fmt(entry.date)}</span>
            <strong>{entry.title}</strong>
            <em>Read more</em>
          </a>
        ))}
      </div>

      <div class="callout">
        More Moonlight Peaks coverage: <a href="/release-date">release date</a>, <a href="/platforms">platforms</a>, <a href="/demo">demo guide</a>, and <a href="/previews">articles</a>.
      </div>
    </div>
  </article>

  <style>
    .news-page .intro { max-width: 72ch; }
    .news-body-long { max-width: 74ch; margin-top: 28px; }
    .news-body-long p { font-size: 1.02rem; }
    .news-related { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
    @media (max-width: 760px) { .news-related { grid-template-columns: 1fr; } }
    .news-related-card { display: flex; flex-direction: column; gap: 6px; border: 1px solid var(--line); border-radius: 12px; background: var(--surface); padding: 15px; transition: border-color .15s ease, transform .15s ease; }
    .news-related-card:hover { border-color: color-mix(in srgb, var(--candle) 50%, var(--line)); transform: translateY(-2px); }
    .news-related-card span { font-family: var(--mono); font-size: 0.68rem; color: var(--candle); text-transform: uppercase; letter-spacing: 0.08em; }
    .news-related-card strong { color: var(--mist); font-family: var(--display); line-height: 1.18; }
    .news-related-card em { margin-top: auto; color: var(--candle); font-style: normal; font-family: var(--mono); font-size: 0.72rem; }
  </style>
</Base>
