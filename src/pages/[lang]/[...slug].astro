---
import SeoProgramPage from '../../components/SeoProgramPage.astro';
import { localizedStaticPages } from '../../data/localizedStaticPages';
import { localizeSeoPage, localizedLocales, type LocaleCode } from '../../data/i18n';
import { seoPages, type SeoPage } from '../../data/seoGraph';

const uniquePages = (pages: SeoPage[]): SeoPage[] => {
  const seen = new Set<string>();
  return pages.filter((page) => {
    if (seen.has(page.path)) return false;
    seen.add(page.path);
    return true;
  });
};

const sourcePages = uniquePages([...localizedStaticPages, ...seoPages]);

export function getStaticPaths() {
  return localizedLocales.flatMap((locale) =>
    sourcePages.map((page) => ({
      params: {
        lang: locale.code,
        slug: page.path === '/' ? undefined : page.path.replace(/^\//, ''),
      },
      props: {
        locale: locale.code,
        sourcePath: page.path,
        page: localizeSeoPage(page, locale.code as LocaleCode),
      },
    }))
  );
}

const { page, locale, sourcePath } = Astro.props;
---
<SeoProgramPage page={page} sourcePath={sourcePath} locale={locale} />
