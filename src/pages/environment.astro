---
import Base from '../layouts/Base.astro';
import { SITE, GAME } from '../consts';

const systems: { name: string; note: string }[] = [
  { name: 'Weather', note: 'Day-to-day conditions that likely affect farming, foraging, or what you can do outdoors.' },
  { name: 'Seasons', note: 'A season or calendar system to structure crops and events —exact names and length unconfirmed.' },
  { name: 'Festivals', note: 'Town-wide celebrations. A theatrical event host has already been shown livening up gatherings.' },
];

const faq = [
  { q: 'Does Moonlight Peaks have seasons?', a: 'Pre-launch datamined game files list a "Seasons" system, suggesting the game structures its calendar around them, similar to other farming sims. Specific season names and lengths are not yet developer-confirmed.' },
  { q: 'Does Moonlight Peaks have weather?', a: 'Yes, based on datamined files, which list a "Weather" system. How weather affects farming or activities is confirmed at launch.' },
  { q: 'Are there festivals in Moonlight Peaks?', a: 'Datamined files list a "Festivals" system, and a theatrical event host has already been shown livening up town gatherings in coverage —consistent with seasonal celebrations being part of town life.' },
];

const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Environment', item: new URL('/environment', SITE.url).href },
  ] },
];
---
<Base
  title="Moonlight Peaks Environment — Weather, Seasons & Festivals"
  description="What's known about weather, seasons, and festivals in Moonlight Peaks, based on pre-launch datamined game files — confirmed, expected, and still unknown."
  path="/environment"
  jsonLd={jsonLd}
  crumbs={[{ label: 'Environment' }]}
>
  <article class="page">
    <div class="wrap">
      <p class="eyebrow">Hub 路 Environment</p>
      <h1>Moonlight Peaks <em>environment</em></h1>
      <p class="intro">
        How the world of {GAME.title} changes over time —weather, seasons, and town festivals.
        The systems below are named in pre-launch datamined game files and treated as launch-pending:
        useful for tracking likely systems, but not enough to confirm exact rules. Updated {SITE.updated}.
      </p>

      <h2>Systems we expect</h2>
      <div class="envg">
        {systems.map((s) => (
          <div class="envcard">
            <h3>{s.name}</h3>
            <p>{s.note}</p>
            <span class="envbadge">Datamined</span>
          </div>
        ))}
      </div>

      <h2>The night-first twist</h2>
      <p>
        Whatever the season or weather, one rule stays constant: you live and farm at night and head
        back to your coffin before sunrise. See <a href="/farming">farming</a> for how the night cycle
        shapes the core gameplay loop, and <a href="/locations/town-square">town square</a> for what's
        known about where festivals might happen.
      </p>

      <h2>Coming at launch ({GAME.releaseLabel})</h2>
      <ul>
        <li>The actual <strong>season names</strong> and how long each one lasts.</li>
        <li><strong>Weather types</strong> and their effect on farming or activities.</li>
        <li>Which <strong>festivals</strong> happen, and when.</li>
      </ul>

      <h2>FAQ</h2>
      <div class="faq">
        {faq.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <div class="callout wip">
        Pre-launch entry —season, weather, and festival specifics land at launch. Related:
        <a href="/farming">farming</a>, <a href="/items">items</a>, <a href="/locations">locations</a>.
      </div>
    </div>
  </article>

  <style>
    .envg { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 6px 0 18px; }
    @media (min-width: 640px) { .envg { grid-template-columns: 1fr 1fr 1fr; } }
    .envcard { border: 1px solid var(--line); border-radius: 14px; background: var(--surface); padding: 14px; }
    .envcard h3 { font-family: var(--display); font-weight: 600; font-size: 1rem; margin: 0 0 6px; }
    .envcard p { color: #ded3e6; font-size: 0.84rem; margin: 0 0 8px; }
    .envbadge { font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.04em; text-transform: uppercase; color: #9ac6e0; border: 1px solid #2f5a70; border-radius: 5px; padding: 2px 6px; }
  </style>
</Base>


