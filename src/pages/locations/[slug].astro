---
import TopicPage from '../../components/TopicPage.astro';
import { locationsSection, locations } from '../../data/locations';

export function getStaticPaths() {
  return locations.map((it, i) => ({
    params: { slug: it.slug },
    props: { item: it, prev: locations[(i - 1 + locations.length) % locations.length], next: locations[(i + 1) % locations.length] },
  }));
}
const { item, prev, next } = Astro.props;
---
<TopicPage section={locationsSection} item={item} prev={prev} next={next} />
